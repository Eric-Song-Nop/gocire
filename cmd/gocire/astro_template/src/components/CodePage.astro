---
import Check from "lucide-astro/Check";
import Copy from "lucide-astro/Copy";
import SiteLayout from "../layouts/SiteLayout.astro";
import NavigationRail from "./NavigationRail.astro";
import Sidebar from "./Sidebar.astro";

interface TableOfContentsItem {
  level?: number;
  id?: string;
  title?: string;
}

interface Props {
  title: string;
  kind?: string;
  language?: string;
  sourcePath?: string;
  date?: string;
  tags?: string[];
  author?: string;
  renderMode?: string;
  toc?: TableOfContentsItem[];
}

const {
  title,
  kind = "Source",
  language,
  sourcePath,
  renderMode = "source",
  toc = [],
} = Astro.props;
const tocItems = compactToc(toc);
const hasToc = tocItems.length > 0;
const pageClass = [
  "site-shell",
  "code-page",
  "code-page--" + renderMode,
  hasToc ? "code-page--has-toc" : "",
].filter(Boolean).join(" ");
const currentPath = Astro.url.pathname;

function compactToc(values?: TableOfContentsItem[]) {
  return (values ?? []).map((item) => ({
    level: Math.min(4, Math.max(1, Number(item.level) || 1)),
    id: String(item.id || "").trim(),
    title: String(item.title || "").trim(),
  })).filter((item) => item.id && item.title);
}
---

<SiteLayout title={title}>
  <template id="gocire-code-copy-icon">
    <Copy size={16} aria-hidden="true" />
  </template>
  <template id="gocire-code-copy-success-icon">
    <Check size={16} aria-hidden="true" />
  </template>
  <main class={pageClass}>
    <Sidebar kind={kind} sourcePath={sourcePath} language={language} currentPath={currentPath} />

    <div class="page-main">
      <section class="page-content" aria-label={"Content for " + title}>
        <slot />
      </section>
    </div>

    {hasToc && <NavigationRail items={tocItems} />}
  </main>
</SiteLayout>
